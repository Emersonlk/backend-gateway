{
	"info": {
		"_postman_id": "backend-gateway-api",
		"name": "Backend Gateway API",
		"description": "API RESTful do sistema gerenciador de pagamentos multi-gateway.\n\n**Uso:**\n1. Execute **Login** (admin@example.com / password).\n2. O token é salvo automaticamente; as demais rotas usam **Authorization: Bearer {{token}}**.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api"
		},
		{
			"key": "token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    if (json.token) {",
									"        pm.collectionVariables.set('token', json.token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Autentica e retorna token. O token é salvo na variável da collection para uso nas rotas protegidas."
					}
				},
				{
					"name": "User (me)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/user",
							"host": ["{{base_url}}"],
							"path": ["user"]
						},
						"description": "Retorna o usuário autenticado (id, name, email, role). Requer token."
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/logout",
							"host": ["{{base_url}}"],
							"path": ["logout"]
						},
						"description": "Revoga o token atual. Requer token."
					}
				}
			]
		},
		{
			"name": "Public",
			"item": [
				{
					"name": "Purchase (múltiplos produtos)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"client\": {\n        \"name\": \"Cliente Teste\",\n        \"email\": \"cliente@example.com\"\n    },\n    \"products\": [\n        {\n            \"product_id\": 1,\n            \"quantity\": 1\n        },\n        {\n            \"product_id\": 2,\n            \"quantity\": 2\n        }\n    ],\n    \"card\": {\n        \"number\": \"5569000000006063\",\n        \"cvv\": \"010\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/purchase",
							"host": ["{{base_url}}"],
							"path": ["purchase"]
						},
						"description": "Realiza uma compra com múltiplos produtos. Não exige autenticação na nossa API. Os dados são enviados aos gateways seguindo a prioridade configurada."
					}
				}
			]
		},
