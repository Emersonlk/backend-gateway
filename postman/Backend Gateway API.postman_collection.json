					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"priority\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/gateways/2/priority",
							"host": ["{{base_url}}"],
							"path": ["gateways", "2", "priority"]
						}
					}
				}
			]
		},
